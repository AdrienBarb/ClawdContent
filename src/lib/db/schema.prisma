datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                         String           @id
  name                       String
  email                      String
  emailVerified              Boolean          @default(false)
  image                      String?
  createdAt                  DateTime         @default(now())
  updatedAt                  DateTime         @default(now()) @updatedAt
  sessions                   Session[]
  accounts                   Account[]
  subscription               Subscription?
  lateProfile                LateProfile?
  timezone                   String?
  media                      Media[]
  websiteUrl                 String?
  businessDescription        String?
  knowledgeBase              Json?
  postsPublished             Int              @default(0)
  lastSuggestionsGeneratedAt DateTime?
  usageLedger                UsageLedger[]
  outcomeSnapshot            OutcomeSnapshot?

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeCustomerId     String    @unique
  stripeSubscriptionId String    @unique
  status               String    @default("incomplete") // active, past_due, canceled, incomplete, trialing
  planId               String    @default("pro") // starter, pro, business
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@map("subscription")
}

model LateProfile {
  id             String          @id @default(cuid())
  userId         String          @unique
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  lateProfileId  String          @unique
  lateApiKey     String
  profileName    String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  socialAccounts SocialAccount[]

  @@map("late_profile")
}

model SocialAccount {
  id             String           @id @default(cuid())
  lateProfileId  String
  lateProfile    LateProfile      @relation(fields: [lateProfileId], references: [id], onDelete: Cascade)
  lateAccountId  String           @unique
  platform       String
  username       String
  status         String           @default("active") // active, disconnected
  analysisStatus String           @default("pending") // pending, analyzing, completed
  insights       Json?
  lastAnalyzedAt DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  suggestions    PostSuggestion[]

  @@index([lateProfileId])
  @@map("social_account")
}

model PostSuggestion {
  id              String        @id @default(cuid())
  socialAccountId String
  socialAccount   SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  content         String
  contentType     String // text, image, video, carousel
  suggestedDay    Int // 0=Monday, 6=Sunday
  suggestedHour   Int // 0-23 local time
  reasoning       String?
  mediaItems      Json? // [{url, type: "image"|"video"}, ...]
  scheduledAt     DateTime?
  createdAt       DateTime      @default(now())

  // --- Publish-flow idempotency ---
  // Stamped just before we hit Zernio. Acts as a soft lock so a second click
  // before the response lands is rejected with "already in progress".
  publishingStartedAt DateTime?
  // The Zernio post id Zernio handed back, captured AFTER createPost succeeds.
  // If a transient DB error stops the cleanup transaction from committing,
  // this field stays null but is populated by retry logic; if it's already
  // set on retry, we skip the second Zernio call (avoids double-post).
  publishedExternalId String?

  @@index([socialAccountId])
  @@map("post_suggestion")
}

model Media {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cloudinaryId String   @unique
  url          String
  resourceType String
  format       String
  bytes        Int
  width        Int?
  height       Int?
  createdAt    DateTime @default(now())

  @@map("media")
}

model StripeEvent {
  id          String   @id // Stripe event ID (evt_xxx)
  processedAt DateTime @default(now())

  @@map("stripe_event")
}

// Posts-only outcome snapshot, recomputed nightly from Zernio analytics.
// Read once at the top of each chat request and projected into the system
// prompt as a compact bullet list — saves the model from fishing with a tool
// call and saves N analytics round-trips per chat. One row per user; missing
// row = no signal yet (user hasn't published enough).
//   topPerformers/underperformers — { id, content, platform, metric, value, vsAverage }[]
//   patterns                       — { bestPlatform, bestHour, bestContentType }
//   failedPosts                    — { platform, count, lastError? }[]
model OutcomeSnapshot {
  userId          String   @id
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  computedAt      DateTime @default(now())
  publishedCount  Int      @default(0)
  topPerformers   Json // shaped above
  underperformers Json
  patterns        Json
  failedPosts     Json

  @@map("outcome_snapshot")
}

// Event-sourced ledger for AI usage allowance.
// amount: negative = consume, positive = grant or refund.
// bucket conventions:
//   "free-lifetime"               → free user, never resets
//   "period:{ISO-date}"           → Pro user, resets per Stripe billing period
//   "topup:{stripeSessionId}"     → one-time pack, never expires
// dedupKey enforces idempotency across retries / webhook redelivery /
// AI SDK tool-call replays. Examples:
//   "consume:{toolCallId}"
//   "refund:{toolCallId}:partial"
//   "period:{stripeSubscriptionId}:{ISO}:{type}"
//   "topup:{stripeSessionId}"
model UsageLedger {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // "draft_generation" | "rewrite"
  amount    Int
  bucket    String
  reason    String // "consume" | "refund" | "subscription_grant" | "topup_grant"
  dedupKey  String
  metadata  Json?
  createdAt DateTime @default(now())

  @@unique([userId, dedupKey])
  @@index([userId, type])
  @@index([userId, bucket])
  @@map("usage_ledger")
}
