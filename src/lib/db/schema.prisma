datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                         String           @id
  name                       String
  email                      String
  emailVerified              Boolean          @default(false)
  image                      String?
  createdAt                  DateTime         @default(now())
  updatedAt                  DateTime         @default(now()) @updatedAt
  sessions                   Session[]
  accounts                   Account[]
  subscription               Subscription?
  lateProfile                LateProfile?
  timezone                   String?
  media                      Media[]
  websiteUrl                 String?
  businessDescription        String?
  knowledgeBase              Json?
  onboardingStep             Int              @default(1)
  onboardingCompletedAt      DateTime?
  websiteAnalysis            Json?
  onboardingGoal             String?
  postsPublished             Int              @default(0)
  lastSuggestionsGeneratedAt DateTime?
  outcomeSnapshot            OutcomeSnapshot?

  // --- Autopilot ---
  // autopilotMode: "full_auto" (default — weekly batches commit to Zernio
  // immediately) | "review" (batch is staged locally until the user approves).
  autopilotMode    String        @default("full_auto")
  // Set when the user pauses the autopilot; dispatch skips paused users.
  autopilotPausedAt DateTime?
  // One-shot steering note ("we launch the summer menu Tuesday") consumed and
  // cleared by the next weekly batch.
  pendingBrief     String?
  // Frozen per-user visual brand kit (logo URL, hex palette, style-anchor
  // phrase, reference image URLs) built once from knowledgeBase.branding —
  // keeps generated media visually consistent week over week.
  styleKit         Json?
  weeklyBatches    WeeklyBatch[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeCustomerId     String    @unique
  stripeSubscriptionId String    @unique
  status               String    @default("incomplete") // active, past_due, canceled, incomplete, trialing
  planId               String    @default("pro") // starter, pro, business
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@map("subscription")
}

model LateProfile {
  id             String          @id @default(cuid())
  userId         String          @unique
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  lateProfileId  String          @unique
  lateApiKey     String
  profileName    String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  socialAccounts SocialAccount[]

  @@map("late_profile")
}

model SocialAccount {
  id             String           @id @default(cuid())
  lateProfileId  String
  lateProfile    LateProfile      @relation(fields: [lateProfileId], references: [id], onDelete: Cascade)
  lateAccountId  String           @unique
  platform       String
  username       String
  status         String           @default("active") // active, disconnected
  analysisStatus String           @default("pending") // pending, analyzing, completed
  insights       Json?
  // LLM-authored growth strategy (positioning, pillars, post ideas, cadence/
  // format plan, double-down/stop). Shape: src/lib/schemas/strategy.ts. Built
  // after insights in analyze-account / refresh-insights. Null until generated.
  strategy       Json?
  lastAnalyzedAt DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  suggestions    PostSuggestion[]

  @@index([lateProfileId])
  @@map("social_account")
}

model PostSuggestion {
  id              String        @id @default(cuid())
  socialAccountId String
  socialAccount   SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  content         String
  contentType     String // text, image, video, carousel
  suggestedDay    Int // 0=Monday, 6=Sunday
  suggestedHour   Int // 0-23 local time
  reasoning       String?
  mediaItems      Json? // [{url, type: "image"|"video"}, ...]
  scheduledAt     DateTime?
  createdAt       DateTime      @default(now())
  // Weekly autopilot batch this draft belongs to (null = manual/chat draft).
  batchId         String?
  batch           WeeklyBatch?  @relation(fields: [batchId], references: [id], onDelete: SetNull)
  // "draft" (normal) | "needs_media" (media generation failed twice — post is
  // held back from commit and surfaced in the digest/attention strip).
  status          String        @default("draft")

  // --- Publish-flow idempotency ---
  // Stamped just before we hit Zernio. Acts as a soft lock so a second click
  // before the response lands is rejected with "already in progress".
  publishingStartedAt DateTime?
  // The Zernio post id Zernio handed back, captured AFTER createPost succeeds.
  // If a transient DB error stops the cleanup transaction from committing,
  // this field stays null but is populated by retry logic; if it's already
  // set on retry, we skip the second Zernio call (avoids double-post).
  publishedExternalId String?

  @@index([socialAccountId])
  @@index([batchId])
  @@map("post_suggestion")
}

// One row per user per autopilot week. Acts as the idempotency anchor for the
// Sunday dispatch (unique [userId, weekStart]) and the source for the digest
// email + dashboard status banner.
//   status: "generating" | "ready" | "failed"
//   mode:   "full_auto" | "review" — snapshot of User.autopilotMode at generation
//   posts:  compact snapshot for digest/attention rendering —
//           [{ externalPostId?, suggestionId?, accountId, platform, username,
//              scheduledAt, contentPreview, mediaUrl?, mediaType?, status,
//              retriedAt? }]
model WeeklyBatch {
  id           String           @id @default(cuid())
  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStart    DateTime
  status       String           @default("generating")
  mode         String           @default("full_auto")
  brief        String?
  posts        Json?
  error        String?
  digestSentAt DateTime?
  approvedAt   DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  suggestions  PostSuggestion[]

  @@unique([userId, weekStart])
  @@index([userId])
  @@map("weekly_batch")
}

model Media {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  storagePath  String   @unique
  url          String
  resourceType String
  format       String
  bytes        Int
  width        Int?
  height       Int?
  createdAt    DateTime @default(now())

  @@map("media")
}

model StripeEvent {
  id          String   @id // Stripe event ID (evt_xxx)
  processedAt DateTime @default(now())

  @@map("stripe_event")
}

// Posts-only outcome snapshot, recomputed nightly from Zernio analytics.
// Read once at the top of each chat request and projected into the system
// prompt as a compact bullet list — saves the model from fishing with a tool
// call and saves N analytics round-trips per chat. One row per user; missing
// row = no signal yet (user hasn't published enough).
//   topPerformers/underperformers — { id, content, platform, metric, value, vsAverage }[]
//   patterns                       — { bestPlatform, bestHour, bestContentType }
//   failedPosts                    — { platform, count, lastError? }[]
model OutcomeSnapshot {
  userId          String   @id
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  computedAt      DateTime @default(now())
  publishedCount  Int      @default(0)
  topPerformers   Json // shaped above
  underperformers Json
  patterns        Json
  failedPosts     Json

  @@map("outcome_snapshot")
}
