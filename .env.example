# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54325/postgres"
DIRECT_URL="postgresql://postgres:postgres@127.0.0.1:54325/postgres"

# Authentication (Better Auth)
BETTER_AUTH_SECRET=your_better_auth_secret_here_min_32_chars
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Email (Resend)
RESEND_API_KEY=your_resend_api_key_here

# Analytics (PostHog)
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# App Environment
NEXT_PUBLIC_APP_ENV=development

# Payments (Stripe)
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# Rate Limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL=your_upstash_redis_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token_here

# Railway (Container Provisioning)
RAILWAY_API_TOKEN=your_railway_api_token_here
RAILWAY_DEFAULT_PROJECT_ID=your_railway_project_id_here

# OpenClaw Docker Image
OPENCLAW_IMAGE=ghcr.io/adrienbarb/postclaw-agent:latest

# Late API (Social Media Posting)
LATE_API_KEY=your_late_api_key_here
